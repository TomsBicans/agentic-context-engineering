@startuml
title Experiment Runner - Batch Execution Flow

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam activity {
  BackgroundColor #F8F8F8
  BorderColor #555555
  DiamondBackgroundColor #FFF7E6
  DiamondBorderColor #555555
}

start

:Parse CLI or dashboard request;

note right
  Alternative entry: **suite run --config <file>**
  expands a YAML config into multiple single-system
  tasks and executes them with resumable state
  tracking (suite plan / run / status / cancel).
end note

:Build RunConfig\n(system, corpus, model,\nautomation level, corpus path,\nreasoning_enabled, num_ctx, store_trace);
:Load question file;

if (Question IDs selected?) then (yes)
  :Filter question list;
  if (Any selected ID missing?) then (yes)
    :Raise configuration error;
    stop
  endif
endif

if (Dry run?) then (yes)
  :Print resolved configuration\nand selected questions;
  stop
endif

:Create unique output JSONL path;

if (System requires corpus isolation?\nACE, Claude Code Local, Codex, ClawCode) then (yes)

  repeat
    :Take next question;
    :Copy corpus to tmpfs (/dev/shm)\nor /tmp if space insufficient;
    :Capture pre-run filesystem snapshot\n(CorpusSnapshot.pre_run_tree);
    :Instantiate runner → setup();
    :runner.run(question);
    :runner.teardown();
    :Capture post-run filesystem snapshot\n(CorpusSnapshot.post_run_tree);

    if (Run succeeds?) then (yes)
      :Collect answer text, metrics,\noptional session trace;
    else (no)
      :Store answer_error in RunResult;
    endif

    :Attach CorpusSnapshot to RunResult;
    :Append RunResult JSON as one JSONL row;
    :Flush output file;
    :Remove temporary corpus copy;
  repeat while (More questions?) is (yes)

else (no)

  :Instantiate system runner\nthrough runner registry;
  :runner.setup();

  repeat
    :Take next question;
    :runner.run(question);

    if (Run succeeds?) then (yes)
      :Collect answer text,\nmetrics, and optional trace;
    else (no)
      :Store answer_error in RunResult\ninstead of aborting the batch;
    endif

    :Append RunResult JSON\nas one JSONL row;
    :Flush output file;
  repeat while (More questions?) is (yes)

  :runner.teardown();

endif

:Print result file path;

stop

legend right
  Main purpose:
  execute the same question set against
  different systems while preserving a
  common result schema for later analysis.
  |= Field |= Populated by |
  | answer_text, execution_time_s | all runners |
  | tool_call_sequence, step_count | ACE, local CLI runners |
  | token counts | runners with structured output |
  | CorpusSnapshot | isolated-corpus runs only |
endlegend

@enduml
